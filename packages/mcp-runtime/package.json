{
  "name": "@switchboard-mcp/mcp-runtime",
  "version": "0.1.2",
  "type": "module",
  "description": "MCP runtime, routing, daemon client, and stdio server helpers for Switchboard.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wkoverfield/switchboard.git",
    "directory": "packages/mcp-runtime"
  },
  "homepage": "https://github.com/wkoverfield/switchboard#readme",
  "bugs": {
    "url": "https://github.com/wkoverfield/switchboard/issues"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:daemon-mcp-list-tools": "node scripts/smoke-daemon-mcp-list-tools.mjs",
    "smoke:github-ci-first-loop": "node scripts/smoke-github-ci-first-loop.mjs",
    "smoke:mandate-secret-ref": "node scripts/smoke-mandate-secret-ref.mjs",
    "smoke:mandate-walkthrough": "node scripts/smoke-mandate-walkthrough.mjs",
    "smoke:secret-ref-profile": "node scripts/smoke-secret-ref-profile.mjs",
    "smoke:serve-session": "node scripts/smoke-serve-session.mjs"
  },
  "dependencies": {
    "@switchboard-mcp/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
