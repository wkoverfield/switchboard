{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.wkoverfield/switchboard",
  "description": "One firewall and password manager for all your AI coding agents' MCP servers and secrets: scoped, expiring access to their tools.",
  "version": "0.2.1",
  "repository": {
    "url": "https://github.com/wkoverfield/switchboard",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@switchboard-mcp/cli",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ]
    }
  ]
}
