{
  "name": "switchboard",
  "private": true,
  "type": "module",
  "version": "0.1.2",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "description": "Local-first MCP profile router for multiple accounts, projects, environments, and AI coding agents.",
  "scripts": {
    "build": "pnpm -r build",
    "switchboard": "node apps/cli/dist/index.js",
    "typecheck": "pnpm build && pnpm -r typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "smoke:cli-help": "pnpm --filter @switchboard-mcp/cli smoke:help",
    "smoke:source-cli": "pnpm switchboard --help",
    "smoke:cli-status": "pnpm --filter @switchboard-mcp/cli switchboard status --json",
    "smoke:cli-doctor": "pnpm --filter @switchboard-mcp/cli switchboard doctor --json",
    "smoke:repo-config": "tmpfile=$(mktemp) && pnpm --silent --filter @switchboard-mcp/cli switchboard status --json > \"$tmpfile\" && node scripts/smoke/assert-repo-config.mjs \"$tmpfile\"",
    "smoke:init": "tmpdir=$(mktemp -d) && repo=$PWD && (cd \"$tmpdir\" && node \"$repo/apps/cli/dist/index.js\" --cwd \"$tmpdir\" init --json); status=$?; rm -rf \"$tmpdir\"; exit $status",
    "smoke:profile-test": "tmpdir=$(mktemp -d) && repo=$PWD && (cd \"$tmpdir\" && XDG_STATE_HOME=\"$tmpdir\" node \"$repo/apps/cli/dist/index.js\" --cwd \"$repo\" test switchboard_fixture --json); status=$?; rm -rf \"$tmpdir\"; exit $status",
    "smoke:audit-profile-test": "tmpdir=$(mktemp -d) && repo=$PWD && (cd \"$tmpdir\" && XDG_STATE_HOME=\"$tmpdir\" node \"$repo/apps/cli/dist/index.js\" --cwd \"$repo\" test switchboard_fixture --json >/dev/null && XDG_STATE_HOME=\"$tmpdir\" node \"$repo/apps/cli/dist/index.js\" logs --json); status=$?; rm -rf \"$tmpdir\"; exit $status",
    "smoke:secret-ref-profile": "pnpm --filter @switchboard-mcp/mcp-runtime smoke:secret-ref-profile",
    "smoke:mandate-secret-ref": "pnpm --filter @switchboard-mcp/mcp-runtime smoke:mandate-secret-ref",
    "smoke:provider-add": "node scripts/smoke/provider-add.mjs",
    "smoke:import-dry-run": "node scripts/smoke/import-dry-run.mjs",
    "smoke:audit-v0": "node scripts/smoke/audit-v0.mjs",
    "smoke:repo-manifest": "node scripts/smoke/repo-manifest.mjs",
    "smoke:authority-map-draft": "node scripts/smoke/authority-map-draft.mjs",
    "smoke:provider-presets": "node scripts/smoke/provider-presets.mjs",
    "smoke:package-pack": "node scripts/smoke/package-pack.mjs",
    "smoke:package-install": "node scripts/smoke/package-install.mjs",
    "release:npm-alpha:preflight": "node scripts/release/npm-alpha-preflight.mjs",
    "smoke:github-ci-first-loop": "pnpm --filter @switchboard-mcp/mcp-runtime smoke:github-ci-first-loop",
    "smoke:harness-subagent-proof": "node scripts/smoke/harness-subagent-proof.mjs",
    "smoke:mandate-runtime-readiness": "node scripts/smoke/mandate-runtime-readiness.mjs",
    "smoke:stripe-test-dogfood": "node scripts/smoke/stripe-test-dogfood.mjs",
    "smoke:stripe-test-live-dogfood": "node scripts/smoke/stripe-test-live-dogfood.mjs",
    "smoke:supabase-dev-dogfood": "node scripts/smoke/supabase-dev-dogfood.mjs",
    "smoke:supabase-dev-live-dogfood": "node scripts/smoke/supabase-dev-live-dogfood.mjs",
    "smoke:vercel-preview-dogfood": "node scripts/smoke/vercel-preview-dogfood.mjs",
    "smoke:vercel-preview-live-dogfood": "node scripts/smoke/vercel-preview-live-dogfood.mjs",
    "smoke:grant-badge": "node scripts/smoke/grant-badge.mjs",
    "smoke:mandate-lifecycle": "node scripts/smoke/mandate-lifecycle.mjs",
    "smoke:mandate-lease-evidence": "node scripts/smoke/mandate-lease-evidence.mjs",
    "smoke:install-codex": "tmpdir=$(mktemp -d) && repo=$PWD && outfile=\"$tmpdir/codex.json\" && (cd \"$tmpdir\" && node \"$repo/apps/cli/dist/index.js\" --cwd \"$repo\" install codex --json > \"$outfile\" && node \"$repo/scripts/smoke/assert-install-snippet.mjs\" codex \"$outfile\"); status=$?; rm -rf \"$tmpdir\"; exit $status",
    "smoke:install-claude": "tmpdir=$(mktemp -d) && repo=$PWD && outfile=\"$tmpdir/claude.json\" && (cd \"$tmpdir\" && node \"$repo/apps/cli/dist/index.js\" --cwd \"$repo\" install claude --json > \"$outfile\" && node \"$repo/scripts/smoke/assert-install-snippet.mjs\" claude \"$outfile\"); status=$?; rm -rf \"$tmpdir\"; exit $status",
    "smoke:install-write-codex": "node scripts/smoke/install-write.mjs codex",
    "smoke:install-write-claude": "node scripts/smoke/install-write.mjs claude",
    "smoke:daemon-lifecycle": "node scripts/smoke/daemon-lifecycle.mjs",
    "smoke:daemon-list-tools": "node scripts/smoke/daemon-list-tools.mjs",
    "smoke:daemon-mcp-list-tools": "pnpm --filter @switchboard-mcp/mcp-runtime smoke:daemon-mcp-list-tools",
    "smoke:mandate-walkthrough": "pnpm --filter @switchboard-mcp/mcp-runtime smoke:mandate-walkthrough",
    "smoke:mcp-serve-session": "pnpm --filter @switchboard-mcp/mcp-runtime smoke:serve-session",
    "eval:fresh-agent-import": "node scripts/evals/fresh-agent.mjs import",
    "eval:fresh-agent-package-import": "node scripts/evals/fresh-agent.mjs package-import",
    "eval:blind-alpha": "node scripts/evals/fresh-agent.mjs blind-alpha",
    "eval:fresh-agent-github-ci": "node scripts/evals/fresh-agent.mjs github-ci",
    "eval:fresh-agent-authority-map": "node scripts/evals/fresh-agent.mjs authority-map",
    "eval:fresh-agent-expired-mandate": "node scripts/evals/fresh-agent.mjs expired-mandate",
    "eval:fresh-agent-subagent": "node scripts/evals/fresh-agent.mjs subagent",
    "eval:published-alpha": "node scripts/evals/published-alpha.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.6"
  }
}
