{
  "name": "@switchboard-mcp/cli",
  "mcpName": "io.github.wkoverfield/switchboard",
  "version": "0.2.2",
  "type": "module",
  "description": "One firewall and password manager for all your AI coding agents' MCP servers and secrets.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wkoverfield/switchboard.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/wkoverfield/switchboard#readme",
  "bugs": {
    "url": "https://github.com/wkoverfield/switchboard/issues"
  },
  "bin": {
    "switchboard": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "codex",
    "claude-code",
    "cursor",
    "vscode",
    "supabase",
    "stripe",
    "posthog",
    "sentry",
    "mcp-server",
    "mcp-router",
    "mcp-gateway",
    "tool-calling",
    "developer-tools"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "switchboard": "tsx --conditions source src/index.ts",
    "smoke:help": "tsx --conditions source src/index.ts --help"
  },
  "dependencies": {
    "@switchboard-mcp/core": "workspace:*",
    "@switchboard-mcp/mcp-runtime": "workspace:*",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "tsx": "^4.23.0"
  }
}
